<style>
        body {
            background-color: transparent;
            font-family: 'Inter', sans-serif;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        .glass-panel {
            background: rgba(27, 27, 27, 0.8);
            backdrop-filter: blur(20px);
        }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen p-4 text-on-surface">
<!-- Collapsed Focus Timer Widget (Obsidian HUD Style) -->
<div class="relative group">
<!-- Ambient Glow Shadow (Adjusted to Secondary/Blue-ish for Break) -->
<div class="absolute -inset-1 bg-gradient-to-r from-[#f19a8e]/30 to-primary/10 rounded-2xl blur-2xl opacity-50 group-hover:opacity-75 transition duration-500"></div>
<!-- Main Container -->
<div class="relative glass-panel border border-outline-variant/20 rounded-2xl p-4 w-48 shadow-[0_40px_60px_rgba(198,198,199,0.06)] flex flex-col items-center justify-center space-y-2 cursor-pointer transition-transform duration-200 active:scale-95">
<!-- Resend-style Badge -->
<div class="flex items-center space-x-1.5 px-2.5 py-0.5 bg-surface-container-highest border border-outline-variant/20 rounded-full">
<span class="w-1.5 h-1.5 rounded-full bg-[#f19a8e] animate-pulse"></span>
<span class="text-[10px] font-bold tracking-[0.05em] uppercase text-[#f19a8e]">Break</span>
</div>
<!-- Compact Timer Text -->
<div class="flex flex-col items-center">
<h1 class="text-4xl font-extrabold tracking-tighter text-primary leading-none">
                    05:00
                </h1>
<!-- Tiny progress indicator bar -->
<div class="mt-3 w-32 h-1 bg-surface-container-high rounded-full overflow-hidden">
<div class="h-full w-full rounded-full bg-[#f19a8e]"></div>
</div>
</div>
<!-- Context Action Overlay (Appears on Hover) -->
<div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-surface-container-low/40 rounded-2xl backdrop-blur-sm">
<span class="material-symbols-outlined text-primary text-3xl" data-icon="open_in_full">open_in_full</span>
</div>
</div>
</div>
<!-- Background Decorative Element for Context -->
<div class="fixed inset-0 -z-10 bg-surface overflow-hidden">
<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-surface-container-low/50"></div>
<!-- This represents a blurred work environment in the background -->
<img class="absolute inset-0 w-full h-full object-cover opacity-10 mix-blend-overlay grayscale" data-alt="Modern minimalist home office desk with a clean dark aesthetic, laptop and soft ambient lighting in a professional workspace" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDGVUY9TPMMrr4BpogFGWBrj08eKXbEf22g4I5Bc5W1Iahrdhzb8_pnEL0CNpm1kVffjfM4Y1hLb-9NQYwS47hz3slR55fURwakH9_8n_3IBcmiH7gYtr5WbcQvMT6tdVloT3myJsYMBXh7ebeGDYsduHqgJumSVXk4AYRtNtdXYP_9Up8RSFHl3wVK8f_R3mR2y5ej2UDhpsN46daZjPqnpKrJWjD-F_zRbd8FJIodGwxSepAas5_qKGhLc8v88fxLW6zT9pMTn0A"/>
</div>
</body></html>