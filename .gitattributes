# Normalize line endings to LF in the repo, auto-convert on checkout
* text=auto eol=lf

# Force these to always be LF
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Binary files — no conversion
*.png  binary
*.jpg  binary
*.ico  binary
*.mp3  binary
*.wav  binary
